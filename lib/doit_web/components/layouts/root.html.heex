<!DOCTYPE html>
<html lang="en" class="bg-white dark:bg-zinc-950" data-theme={theme_attr(assigns)}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <link rel="icon" type="image/svg+xml" href={~p"/images/favicon.svg"} />
    <.live_title default="Do It List" suffix=" · Do It List">
      {assigns[:page_title]}
    </.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
    <script>
      (() => {
        // "system" resolves to an explicit light/dark BEFORE first paint, so
        // Tailwind's dark: variant and daisyUI's component vars always read
        // the same data-theme — no attribute means neither ever goes dark.
        const resolve = (theme) =>
          theme === "light" || theme === "dark"
            ? theme
            : (matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
        const setTheme = (theme) => {
          if (theme === "system") {
            localStorage.removeItem("phx:theme");
          } else {
            localStorage.setItem("phx:theme", theme);
          }
          document.documentElement.setAttribute("data-theme", resolve(theme));
          // Marks "following the OS" so the media listener below knows to re-resolve.
          document.documentElement.toggleAttribute("data-theme-system", theme === "system");
        };
        if (!document.documentElement.hasAttribute("data-theme")) {
          setTheme(localStorage.getItem("phx:theme") || "system");
        }
        matchMedia("(prefers-color-scheme: dark)").addEventListener("change", () => {
          if (document.documentElement.hasAttribute("data-theme-system")) setTheme("system");
        });
        window.addEventListener("storage", (e) => e.key === "phx:theme" && setTheme(e.newValue || "system"));
        
        window.addEventListener("phx:set-theme", (e) => {
          // Click via JS.dispatch puts the value on the button's data attribute;
          // server-side push_event puts it in e.detail. Handle both.
          const theme = (e.detail && e.detail.theme) || (e.target && e.target.dataset && e.target.dataset.phxTheme);
          if (theme) setTheme(theme);
        });

        // Light-dismiss for <details data-menu> (e.g. the mobile hamburger):
        // close on an outside click or Escape. Global so it survives LiveView
        // navigation and also works on non-LiveView (dead-view) pages.
        const closeMenus = (pred) => document
          .querySelectorAll("details[data-menu][open]")
          .forEach((d) => { if (pred(d)) d.removeAttribute("open"); });
        document.addEventListener("click", (e) => closeMenus((d) => !d.contains(e.target)));
        document.addEventListener("keydown", (e) => { if (e.key === "Escape") closeMenus(() => true); });
      })();
    </script>
  </head>
  <body class="h-dvh flex flex-col bg-white text-zinc-900 dark:bg-zinc-950 dark:text-zinc-100">
    {@inner_content}
  </body>
</html>
