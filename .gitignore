# The directory Mix will write compiled artifacts to.
/_build/

# If you run "mix test --cover", coverage assets end up here.
/cover/

# The directory Mix downloads your dependencies sources to.
/deps/

# Where 3rd-party dependencies like ExDoc output generated docs.
/doc/

# Ignore .fetch files in case you like to edit your project deps locally.
/.fetch

# If the VM crashes, it generates a dump, let's ignore it too.
erl_crash.dump

# Also ignore archive artifacts (built via "mix archive.build").
*.ez

# Temporary files, for example, from tests.
/tmp/

# Ignore package tarball (built via "mix hex.build").
doit-*.tar

# Ignore assets that are produced by build tools.
/priv/static/assets/

# Ignore digested assets cache.
/priv/static/cache_manifest.json

# In case you use Node.js/npm, you want to ignore these.
npm-debug.log
/assets/node_modules/


# Local, host-specific Docker dev config — not portable, never committed.
# (LAN IP / port bindings live here so the base compose stays portable.)
/compose.override.yaml
/.env

# Local scratch dir (screenshots, notes shared with the agent) — never committed.
/.cybercreek/

# Bruno: keep real API tokens out of git (copy Local.bru.example -> Local.bru)
bruno/environments/Local.bru

# Adapter-written token refresh (m03.04 item 2.13) — a secret, never committed.
/.doitlist/

# mcp_server/ is its own mix project (m03.02) — same build/deps exclusions,
# scoped to its subdirectory since the patterns above are root-anchored.
/mcp_server/_build/
/mcp_server/deps/
